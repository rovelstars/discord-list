# ============================================================
#  Rovel Discord List - Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit your real .env to version control!
# ============================================================


# ------------------------------------------------------------
#  Database (Turso / libSQL)
#  Get these from https://turso.tech after creating a database.
# ------------------------------------------------------------

# The remote libSQL URL for your Turso database.
# Format: libsql://<db-name>-<org>.turso.io
ASTRO_DB_REMOTE_URL=

# The auth token for your Turso database (read-write).
ASTRO_DB_APP_TOKEN=


# ------------------------------------------------------------
#  Discord Application & Bot
#  Create/manage your application at https://discord.com/developers/applications
# ------------------------------------------------------------

# Your Discord Bot's client/application ID.
DISCORD_BOT_ID=

# The Discord server (guild) ID used for admin/logging purposes.
DISCORD_GUILD_ID=

# Role granted to users who have published a bot on the website and are in the server.
# Find or create this role in your Discord server settings and paste its ID here.
DISCORD_BOTDEV_ROLE=

# Role granted to users who have registered an account on the website and are in the server.
# Find or create this role in your Discord server settings and paste its ID here.
DISCORD_USER_ROLE=

# Your Discord application's public key (from the Developer Portal).
DISCORD_PUBLIC_KEY=

# Your Discord application's OAuth2 client secret.
DISCORD_SECRET=

# Your Discord Bot token. Keep this secret!
DISCORD_TOKEN=

# Token used for selfbot/legacy user-account lookups (internal use only).
SELFBOT_TOKEN=


# ------------------------------------------------------------
#  Site / Deployment
# ------------------------------------------------------------

# The full origin URL of this deployment (no trailing slash).
# Used by the Netlify scheduled function to call internal API endpoints.
# Examples:
#   Local dev:  http://localhost:5173
#   Production: https://yourdomain.com
DOMAIN=http://localhost:5173

# Set to "true" if the site is running behind HTTPS in production.
HTTPS=false

# Application environment: "development" | "production"
MODE=development


# ------------------------------------------------------------
#  Internal Security
# ------------------------------------------------------------

# Shared secret used to authenticate calls between the Netlify scheduled
# function and the internal SvelteKit API routes (e.g. /api/internals/refresh-cdn-bgs).
# Generate a strong random value: openssl rand -hex 32
INTERNAL_SECRET=


# ------------------------------------------------------------
#  Logging & Webhooks
# ------------------------------------------------------------

# Discord channel ID where bot approval/removal logs are posted.
LOGS_CHANNEL_ID=

# Discord channel ID where failed DM notifications are logged.
FAILED_DMS_LOGS_CHANNEL_ID=
